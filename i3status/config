# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        colors = true
        interval = 5
}

order += "disk /"
order += "read_file GPU"
order += "ethernet _first_"
order += "memory"
order += "cpu_usage"
order += "battery all"
order += "tztime local"

disk "/" {
    format = " [  %used/%total ] "
}

battery all {
    format = " [    %percentage ] "
    format_down = " [ No Bat ] "
    status_chr = "    "
    status_bat = "    "
    status_full = "    "
    path = "/sys/class/power_supply/BAT%d/uevent"
    low_threshold = 10
}



memory {
    format = " [    %used ] "
}


cpu_usage {
    format = " [  %usage ] "
}


ethernet _first_ {
    format_up = " [    %ip ] "
}


tztime local {
    # Esto pone la hora en grande y la fecha al lado
    format = " [    %H:%M | %d-%m ] "
}
